<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/addressUpdateFragment"
        android:name="com.google.chip.chiptool.clusterclient.AddressUpdateFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteVideoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/addressUpdateFragment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.3" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/remoteVideoView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[Session &amp; Connection State]"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSessionState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting..."
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ICE Gathering State]"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvIceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for ICE gathering..."
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[Complete Offer SDP (with ICE)]"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSdpInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No SDP Info"
                android:textIsSelectable="true"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnCreateOffer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Create Offer SDP" />

            <EditText
                android:id="@+id/etAnswerSdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paste Answer SDP (with ICE)"
                android:minLines="3"
                android:gravity="top"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnSetAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Set Answer SDP &amp; Connect"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>